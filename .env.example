NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DUEL_JOIN_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_EMAILS=

# Preferred screen upstream override for local development.
SCREEN_API_BASE_URL=http://127.0.0.1:8000

# Backward-compatible fallbacks still supported by the repo.
# AGENT_API_BASE_URL=
# NEXT_PUBLIC_AGENT_API_BASE_URL=
#
# BUNS Duel
# reaction | tap-battle | memory-flash
# Used as fallback/default when no runtime value has been set via /api/duel/game.
BUNS_DUEL_ACTIVE_GAME=reaction
# Optional override for the small runtime game selection store.
# BUNS_DUEL_STATE_PATH=.data/duel-active-game.json
# Optional Supabase table for durable runtime game selection.
# BUNS_DUEL_SUPABASE_STATE_TABLE=app_runtime_state
